<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Silvertree — Dashboard Exportación Maderas Korea</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    background: #f5f4f0;
    color: #1a1a18;
    padding: 2rem;
    min-height: 100vh;
  }
  .dash { max-width: 960px; margin: 0 auto; }

  .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 12px; }
  .header-left { display: flex; align-items: center; gap: 12px; }
  .logo { width: 42px; height: 42px; border-radius: 8px; background: #1D9E75; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .header-text h1 { font-size: 19px; font-weight: 500; color: #1a1a18; }
  .header-text p { font-size: 12px; color: #6b6b67; margin-top: 2px; }
  .badge { font-size: 11px; padding: 4px 12px; border-radius: 20px; font-weight: 500; background: #E1F5EE; color: #0F6E56; }

  .metrics { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 10px; margin-bottom: 1.5rem; }
  .metric { background: #edecea; border-radius: 8px; padding: 0.9rem 1rem; }
  .mlabel { font-size: 11px; color: #6b6b67; margin-bottom: 5px; }
  .mval { font-size: 24px; font-weight: 500; color: #1a1a18; line-height: 1; }
  .msub { font-size: 11px; color: #9a9a96; margin-top: 4px; }
  .macc { font-size: 11px; font-weight: 500; margin-top: 4px; color: #0F6E56; }
  .macc-blue { font-size: 11px; font-weight: 500; margin-top: 4px; color: #185FA5; }

  .sec-title { font-size: 13px; font-weight: 500; color: #1a1a18; margin-bottom: 10px; }

  .orders-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(205px, 1fr)); gap: 8px; margin-bottom: 1.5rem; }
  .ocard { border: 0.5px solid rgba(0,0,0,0.12); border-radius: 8px; padding: 10px 12px; background: #fff; }
  .ocard.dy { border-left: 3px solid #378ADD; }
  .ocard-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 5px; }
  .oclient { font-size: 12px; font-weight: 500; color: #1a1a18; }
  .ometa { font-size: 10px; color: #9a9a96; text-align: right; line-height: 1.5; }
  .ovol { font-size: 20px; font-weight: 500; color: #1a1a18; }
  .ounit { font-size: 10px; color: #6b6b67; font-weight: 400; }
  .oprice-total { font-size: 11px; font-weight: 500; color: #0F6E56; margin-top: 4px; margin-bottom: 2px; }
  .esc-table { width: 100%; border-collapse: collapse; margin-top: 4px; }
  .esc-table tr { border-top: 0.5px solid rgba(0,0,0,0.08); }
  .esc-table tr:first-child { border-top: none; }
  .esc-table td { font-size: 10px; padding: 3px 0; vertical-align: middle; }
  .esc-name { color: #1a1a18; }
  .esc-vol { text-align: center; color: #6b6b67; padding: 0 4px; }
  .esc-cbm { text-align: right; font-weight: 500; white-space: nowrap; }
  .cbm-215 { color: #185FA5; }
  .cbm-225 { color: #854F0B; }
  .cbm-280 { color: #6D28D9; }
  .pill { font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 500; display: inline-block; margin-top: 6px; }
  .p-disp { background: #E1F5EE; color: #0F6E56; }
  .p-may  { background: #E6F1FB; color: #185FA5; }
  .p-jun  { background: #EAF3DE; color: #3B6D11; }
  .p-jul  { background: #EDE9FE; color: #5B21B6; }
  .p-aug  { background: #FEF3C7; color: #92400E; }
  .p-sep  { background: #FEE2E2; color: #991B1B; }
  .p-tbd  { background: #F3F4F6; color: #6B7280; }

  .etd-card { background: #fff; border: 0.5px solid rgba(0,0,0,0.12); border-radius: 12px; padding: 1rem 1.25rem; }
  .etd-title { font-size: 13px; font-weight: 500; color: #1a1a18; margin-bottom: 14px; }
  .etd-row { display: flex; align-items: center; gap: 10px; margin-bottom: 9px; }
  .etd-lbl { font-size: 12px; color: #6b6b67; width: 86px; flex-shrink: 0; }
  .etd-track { flex: 1; background: #edecea; border-radius: 4px; height: 24px; overflow: hidden; }
  .etd-fill { height: 100%; border-radius: 4px; display: flex; align-items: center; padding-left: 10px; font-size: 10px; font-weight: 500; white-space: nowrap; overflow: hidden; }
  .etd-num { font-size: 12px; font-weight: 500; color: #1a1a18; width: 62px; text-align: right; flex-shrink: 0; }
  .etd-foot { margin-top: 12px; padding-top: 10px; border-top: 0.5px solid rgba(0,0,0,0.12); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 6px; font-size: 11px; color: #6b6b67; }
  .etd-foot strong { color: #1a1a18; }

  .footer { margin-top: 1.5rem; text-align: center; font-size: 11px; color: #9a9a96; }
</style>
</head>
